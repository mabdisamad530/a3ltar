    <button onclick="closeCart()" style="width:100%;background:transparent;border:1px solid var(--grey);color:var(--muted);padding:12px;font-family:var(--font-display);font-size:16px;letter-spacing:.15em;cursor:pointer;">CONTINUE SHOPPING</button>
  </div>
