<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>A3LTAR — Wear Your Passion</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #080808;
    --deep: #0f0f0f;
    --panel: #141414;
    --red: #C8102E;
    --red-dim: #8a0b1f;
    --white: #f0ece4;
    --grey: #2a2a2a;
    --muted: #666;
    --font-display: 'Bebas Neue', sans-serif;
    --font-body: 'Barlow Condensed', sans-serif;
    --font-mono: 'Share Tech Mono', monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--font-body);
    overflow-x: hidden;
  }
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.035;
    pointer-events: none;
    z-index: 1000;
  }

  /* Announcement */
  .announcement {
    background: var(--red);
    padding: 9px 0;
    overflow: hidden;
  }
  .announcement-track {
    display: flex;
    gap: 60px;
    animation: marquee 22s linear infinite;
    white-space: nowrap;
  }
  .announcement span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--white);
    flex-shrink: 0;
  }
  @keyframes marquee { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

  /* Nav */
  nav {
    position: sticky; top: 0; z-index: 200;
    background: rgba(8,8,8,0.94);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--grey);
    padding: 0 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 66px;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 30px;
    letter-spacing: 0.15em;
    color: var(--white);
    text-decoration: none;
  }
  .nav-logo sup { color: var(--red); font-size: 12px; }
  .nav-links { display:flex; gap:36px; list-style:none; }
  .nav-links a {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }
  .cart-btn {
    background: var(--red);
    color: var(--white);
    border: none;
    padding: 9px 22px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
  }
  .cart-btn:hover { background: var(--red-dim); }

  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    overflow: hidden;
  }
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 80px 60px;
    position: relative;
    z-index: 2;
  }
  .hero-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.2s;
  }
  .hero-tag::before { content:''; width:28px; height:1px; background:var(--red); }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(72px, 9vw, 128px);
    line-height: 0.9;
    color: var(--white);
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.4s;
  }
  .hero-title .accent { color: var(--red); }
  .hero-sub {
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.06em;
    color: rgba(240,236,228,0.55);
    max-width: 340px;
    margin-bottom: 40px;
    line-height: 1.75;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.6s;
  }
  .hero-cta {
    display: flex; gap: 14px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.8s;
  }
  .btn-primary {
    background: var(--red);
    color: var(--white);
    border: none;
    padding: 16px 40px;
    font-family: var(--font-display);
    font-size: 20px;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: background 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--red-dim); }
  .btn-outline {
    background: transparent;
    color: var(--white);
    border: 1px solid var(--grey);
    padding: 16px 40px;
    font-family: var(--font-display);
    font-size: 20px;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: border-color 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-outline:hover { border-color: var(--white); }
  .hero-right {
    position: relative;
    overflow: hidden;
  }
  .hero-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    animation: slowZoom 8s ease forwards;
  }
  .hero-right::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to right, var(--black) 0%, transparent 30%),
                linear-gradient(to top, var(--black) 0%, transparent 20%);
  }
  @keyframes fadeUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
  @keyframes slowZoom { from{transform:scale(1.06)} to{transform:scale(1)} }

  /* Strip */
  .strip {
    border-top: 1px solid var(--grey);
    border-bottom: 1px solid var(--grey);
    padding: 18px 0;
    overflow: hidden;
    background: var(--deep);
  }
  .strip-track {
    display: flex; gap: 48px;
    animation: marquee 28s linear infinite;
    white-space: nowrap;
  }
  .strip span {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.15em;
    color: var(--muted);
    flex-shrink: 0;
  }
  .strip span.r { color: var(--red); }

  /* Products */
  .products { background: var(--deep); padding: 100px 60px; }
  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: flex; align-items: center; gap: 12px;
  }
  .section-label::before { content:''; width:20px; height:1px; background:var(--red); }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(44px, 6vw, 80px);
    line-height: 0.95;
    letter-spacing: 0.04em;
    margin-bottom: 60px;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
  }

  /* Product Card */
  .product-card {
    background: var(--panel);
    position: relative;
    overflow: hidden;
  }
  .product-imgs {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    cursor: pointer;
  }
  .product-imgs img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: opacity 0.5s ease, transform 0.6s ease;
    filter: grayscale(15%);
  }
  .product-imgs img.back { opacity: 0; }
  .product-card:hover .product-imgs img.front { opacity: 0; }
  .product-card:hover .product-imgs img.back { opacity: 1; }
  .product-card:hover .product-imgs img { transform: scale(1.05); filter: grayscale(0%); }
  .product-badge {
    position: absolute; top: 16px; left: 16px;
    background: var(--red);
    color: var(--white);
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 5px 12px;
    z-index: 2;
  }

  /* Size selector */
  .product-bottom { padding: 24px; border-top: 1px solid var(--grey); }
  .product-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
  }
  .product-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .product-price {
    font-family: var(--font-mono);
    font-size: 15px;
    color: var(--red);
  }
  .size-row {
    display: flex;
    gap: 6px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .size-btn {
    width: 42px; height: 42px;
    border: 1px solid var(--grey);
    background: transparent;
    color: var(--muted);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.18s;
  }
  .size-btn:hover { border-color: var(--white); color: var(--white); }
  .size-btn.selected { background: var(--red); border-color: var(--red); color: var(--white); }
  .buy-btn {
    width: 100%;
    background: var(--red);
    color: var(--white);
    border: none;
    padding: 15px;
    font-family: var(--font-display);
    font-size: 20px;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: background 0.2s;
    text-align: center;
  }
  .buy-btn:hover { background: var(--red-dim); }
  .buy-btn:disabled {
    background: var(--grey);
    color: var(--muted);
    cursor: not-allowed;
  }
  .product-desc {
    margin-bottom: 18px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--grey);
  }
  .product-desc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .product-desc-tags span {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--grey);
    padding: 5px 12px;
    transition: color 0.2s, border-color 0.2s;
  }
  .product-desc-tags span:hover { color: var(--white); border-color: var(--white); }
  .product-desc-main {
    font-size: 13px;
    font-weight: 300;
    letter-spacing: 0.06em;
    color: rgba(240,236,228,0.45);
    line-height: 1.7;
    margin-bottom: 14px;
  }

  /* Story */
  .story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 580px;
  }
  .story-img {
    position: relative; overflow: hidden;
  }
  .story-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.65;
  }
  .story-text {
    padding: 100px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--black);
    position: relative;
  }
  .story-text::before {
    content: '"';
    position: absolute;
    top: 40px; left: 60px;
    font-family: var(--font-display);
    font-size: 180px;
    color: var(--grey);
    opacity: 0.25;
    line-height: 1;
  }
  .story-body {
    font-size: 17px;
    font-weight: 300;
    line-height: 1.85;
    color: rgba(240,236,228,0.65);
    margin-bottom: 40px;
    position: relative; z-index: 1;
  }
  .story-body strong { color: var(--white); font-weight: 600; }

  /* Stats */
  .stats {
    background: var(--red);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .stat {
    text-align: center;
    padding: 60px 20px;
    border-left: 1px solid rgba(255,255,255,0.15);
  }
  .stat:first-child { border-left: none; }
  .stat-val {
    font-family: var(--font-display);
    font-size: 68px;
    line-height: 1;
    color: var(--white);
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    margin-top: 8px;
  }

  /* Newsletter */
  .newsletter {
    background: var(--deep);
    text-align: center;
    padding: 120px 60px;
    position: relative; overflow: hidden;
  }
  .newsletter::before {
    content: '';
    position: absolute;
    width: 700px; height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,16,46,0.07) 0%, transparent 70%);
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    pointer-events: none;
  }
  .newsletter .section-title { margin-bottom: 12px; }
  .newsletter .accent { color: var(--red); }
  .newsletter-sub {
    font-size: 16px;
    font-weight: 300;
    color: rgba(240,236,228,0.45);
    letter-spacing: 0.08em;
    margin-bottom: 46px;
  }
  .nl-form {
    display: flex;
    max-width: 480px;
    margin: 0 auto;
  }
  .nl-form input {
    flex: 1;
    background: var(--panel);
    border: 1px solid var(--grey);
    border-right: none;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 15px;
    padding: 15px 22px;
    outline: none;
    transition: border-color 0.2s;
    letter-spacing: 0.05em;
  }
  .nl-form input::placeholder { color: var(--muted); }
  .nl-form input:focus { border-color: var(--red); }
  .nl-form button {
    background: var(--red);
    color: var(--white);
    border: none;
    padding: 15px 30px;
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .nl-form button:hover { background: var(--red-dim); }

  /* Footer */
  footer {
    background: var(--black);
    border-top: 1px solid var(--grey);
    padding: 80px 60px 36px;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 70px;
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 40px;
    letter-spacing: 0.2em;
    margin-bottom: 18px;
  }
  .footer-logo span { color: var(--red); }
  .footer-tagline {
    font-size: 14px; font-weight: 300;
    line-height: 1.8; color: var(--muted);
    max-width: 270px; margin-bottom: 28px;
  }
  .socials { display: flex; gap: 10px; }
  .social {
    width: 38px; height: 38px;
    border: 1px solid var(--grey);
    background: transparent;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 10px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }
  .social:hover { border-color: var(--red); color: var(--red); }
  .footer-col-title {
    font-family: var(--font-body);
    font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase;
    margin-bottom: 22px;
  }
  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 11px; }
  .footer-links a {
    font-size: 14px; font-weight: 300;
    color: var(--muted); text-decoration: none;
    letter-spacing: 0.05em; transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--white); }
  .footer-bottom {
    border-top: 1px solid var(--grey);
    padding-top: 28px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .footer-copy {
    font-family: var(--font-mono);
    font-size: 11px; color: var(--muted); letter-spacing: 0.15em;
  }
  .footer-copy span { color: var(--red); }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 30px; right: 30px;
    background: var(--white);
    color: var(--black);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.15em;
    padding: 14px 24px;
    z-index: 9999;
    transform: translateY(80px);
    opacity: 0;
    transition: all 0.3s ease;
    border-left: 4px solid var(--red);
  }
  .toast.show { transform: translateY(0); opacity: 1; }
  #cart-drawer.open { transform: translateX(0) !important; }
  #cart-overlay.open { display: block !important; opacity: 1 !important; }
  .size-btn.sold-out { opacity: 0.3; text-decoration: line-through; cursor: not-allowed; }

  /* Responsive */
  @media (max-width: 768px) {
    nav { padding: 0 20px; }
    .nav-links { display: none; }
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-right { height: 50vh; }
    .hero-left { padding: 60px 30px; }
    .products { padding: 60px 20px; }
    .products-grid { grid-template-columns: 1fr; }
    .story { grid-template-columns: 1fr; }
    .story-img { height: 300px; }
    .story-text { padding: 60px 30px; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .footer-top { grid-template-columns: 1fr 1fr; gap: 40px; }
    .newsletter { padding: 80px 24px; }
    footer { padding: 60px 24px 30px; }
  }
</style>
</head>
