<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
  const SHOP = 'a3ltar.myshopify.com';
  const TOKEN = 'f7c2678443de076b8ba212f13d7b6997';

  // ── Storefront GraphQL helper ──────────────────────────────────────
  async function sfAPI(query, variables = {}) {
    const res = await fetch(`https://${SHOP}/api/2024-01/graphql.json`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Shopify-Storefront-Access-Token': TOKEN
      },
      body: JSON.stringify({ query, variables })
    });
    return res.json();
  }

  // ── Cart state ─────────────────────────────────────────────────────
  let cartId = null;
  let cartCount = 0;

  async function getOrCreateCart() {
    if (cartId) return cartId;
    const data = await sfAPI(`mutation { cartCreate { cart { id checkoutUrl } } }`);
    cartId = data.data.cartCreate.cart.id;
    window._checkoutUrl = data.data.cartCreate.cart.checkoutUrl;
    return cartId;
  }

  async function addToCart(variantGid, quantity = 1) {
    const id = await getOrCreateCart();
    const data = await sfAPI(`
      mutation cartAdd($cartId: ID!, $lines: [CartLineInput!]!) {
        cartLinesAdd(cartId: $cartId, lines: $lines) {
          cart { id totalQuantity checkoutUrl
            lines(first: 20) { edges { node {
              id quantity
              merchandise { ... on ProductVariant {
                id title price { amount }
                product { title }
                image { url }
              }}
            }}}
          }
        }
      }`, { cartId: id, lines: [{ merchandiseId: variantGid, quantity }] });
    const cart = data.data.cartLinesAdd.cart;
    window._checkoutUrl = cart.checkoutUrl;
    cartCount = cart.totalQuantity;
    document.querySelector('.cart-btn').textContent = `Cart (${cartCount})`;
    renderCartDrawer(cart.lines.edges.map(e => e.node));
    openCart();
  }

  // ── Cart Drawer ────────────────────────────────────────────────────
  function renderCartDrawer(lines) {
    const list = document.getElementById('cart-lines');
    if (!lines.length) { list.innerHTML = '<p style="color:var(--muted);font-size:14px;letter-spacing:.08em;">Your cart is empty.</p>'; return; }
    list.innerHTML = lines.map(line => `
      <div style="display:flex;gap:16px;padding:16px 0;border-bottom:1px solid var(--grey);">
        <img src="${line.merchandise.image?.url || ''}" style="width:70px;height:70px;object-fit:cover;flex-shrink:0;" />
        <div style="flex:1;">
          <div style="font-family:var(--font-body);font-weight:700;font-size:14px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px;">${line.merchandise.product.title}</div>
          <div style="font-family:var(--font-mono);font-size:12px;color:var(--muted);margin-bottom:6px;">${line.merchandise.title} &nbsp;×&nbsp; ${line.quantity}</div>
          <div style="font-family:var(--font-mono);font-size:13px;color:var(--red);">$${parseFloat(line.merchandise.price.amount).toFixed(2)}</div>
        </div>
      </div>`).join('');
  }

  function openCart() {
    document.getElementById('cart-drawer').classList.add('open');
    document.getElementById('cart-overlay').classList.add('open');
  }
  function closeCart() {
    document.getElementById('cart-drawer').classList.remove('open');
    document.getElementById('cart-overlay').classList.remove('open');
  }

  document.querySelector('.cart-btn').addEventListener('click', () => {
    if (cartCount > 0) openCart(); else showToast('Your cart is empty.');
  });

  // ── Load products dynamically ──────────────────────────────────────
  async function loadProducts() {
    const data = await sfAPI(`{
      products(first: 10) { edges { node {
        id title handle
        priceRange { minVariantPrice { amount } }
        images(first: 2) { edges { node { url } } }
        variants(first: 10) { edges { node {
          id title availableForSale
        }}}
      }}}
    }`);

    const products = data.data.products.edges.map(e => e.node);
    const grid = document.getElementById('products-grid');
    grid.innerHTML = '';

    products.forEach((product, idx) => {
      const imgs = product.images.edges.map(e => e.node.url);
      const price = parseFloat(product.priceRange.minVariantPrice.amount).toFixed(2);
      const variants = product.variants.edges.map(e => e.node);
      const badge = idx === 0 ? 'New Drop' : 'New Arrival';

      const card = document.createElement('div');
      card.className = 'product-card';
      card.innerHTML = `
        <span class="product-badge">${badge}</span>
        <div class="product-imgs">
          <img class="front" src="${imgs[0] || ''}" alt="${product.title}" />
          <img class="back" src="${imgs[1] || imgs[0] || ''}" alt="${product.title}" />
        </div>
        <div class="product-bottom">
          <div class="product-meta">
            <span class="product-name">${product.title}</span>
            <span class="product-price">$${price}</span>
          </div>
          <div class="size-row" data-product="${product.id}">
            ${variants.map(v => `
              <button class="size-btn ${!v.availableForSale ? 'sold-out' : ''}"
                data-variant-gid="${v.id}"
                ${!v.availableForSale ? 'disabled title="Sold out"' : ''}>
                ${v.title}
              </button>`).join('')}
          </div>
          <button class="buy-btn" id="buy-${product.id}" disabled onclick="buyProduct('${product.id}', '$${price}')">
            SELECT A SIZE
          </button>
        </div>`;
      grid.appendChild(card);
    });

    // Re-attach size selection listeners
    document.querySelectorAll('.size-row').forEach(row => {
      row.querySelectorAll('.size-btn:not([disabled])').forEach(btn => {
        btn.addEventListener('click', () => {
          row.querySelectorAll('.size-btn').forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
          const productId = row.dataset.product;
          window._selectedVariants = window._selectedVariants || {};
          window._selectedVariants[productId] = btn.dataset.variantGid;
          const buyBtn = document.getElementById('buy-' + productId);
          const price = buyBtn.closest('.product-bottom').querySelector('.product-price').textContent;
          buyBtn.disabled = false;
          buyBtn.textContent = `ADD TO CART — ${price}`;
        });
      });
    });
  }

  async function buyProduct(productId, price) {
    const variantGid = (window._selectedVariants || {})[productId];
    if (!variantGid) { showToast('Select a size first!'); return; }
    const btn = document.getElementById('buy-' + productId);
    btn.textContent = 'ADDING...';
    btn.disabled = true;
    try {
      await addToCart(variantGid);
      showToast('Added to cart!');
    } catch(e) {
      showToast('Something went wrong. Try again.');
    }
    btn.textContent = `ADD TO CART — ${price}`;
    btn.disabled = false;
  }

  // ── Newsletter ─────────────────────────────────────────────────────
  function subscribe() {
    const input = document.querySelector('.nl-form input');
    if (input.value && input.value.includes('@')) {
      showToast("You're in! Welcome to the movement.");
      input.value = '';
    } else {
      showToast('Please enter a valid email.');
    }
  }

  // ── Toast ──────────────────────────────────────────────────────────
  function showToast(msg) {
    const toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
  }

  function goCheckout() {
    if (window._checkoutUrl) window.location.href = window._checkoutUrl;
    else showToast('Your cart is empty.');
  }

  // ── Init ───────────────────────────────────────────────────────────
  loadProducts();
</script>
